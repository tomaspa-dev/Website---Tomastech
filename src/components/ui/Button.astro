---
interface Props {
  href?: string;
  variant?: 'primary' | 'secondary' | 'outline' | 'ghost';
  size?: 'sm' | 'md' | 'lg';
  class?: string;
  [key: string]: any;
}

const { href, variant = 'primary', size = 'md', class: className, ...rest } = Astro.props;

const baseStyles = "inline-flex items-center justify-center rounded-full font-semibold font-heading transition-all duration-300 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-offset-background whitespace-nowrap";

const sizes = {
  sm: "px-5 py-2.5 text-sm gap-2",
  md: "px-7 py-3.5 text-base gap-2.5",
  lg: "px-9 py-4.5 text-lg gap-3",
};

const variants = {
  primary: "bg-primary-500 hover:bg-primary-600 text-white shadow-glow-primary hover:shadow-[0_0_30px_rgba(129,140,248,0.5)] hover:scale-105",
  secondary: "bg-secondary-500 hover:bg-secondary-600 text-white shadow-glow-secondary hover:shadow-[0_0_30px_rgba(192,132,252,0.5)] hover:scale-105",
  outline: "border border-border hover:border-border-hover hover:bg-surface-hover text-text-primary backdrop-blur-sm hover:scale-105",
  ghost: "text-text-secondary hover:text-text-primary hover:bg-surface-hover",
};

const Element = href ? 'a' : 'button';
---

<Element href={href} class:list={[baseStyles, sizes[size], variants[variant], className]} {...rest}>
  <slot />
</Element>
