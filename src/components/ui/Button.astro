---
interface Props {
  href?: string;
  variant?: 'primary' | 'secondary' | 'outline';
  class?: string;
  [key: string]: any;
}

const { href, variant = 'primary', class: className, ...rest } = Astro.props;

const baseStyles = "inline-flex items-center justify-center px-6 py-3 rounded-full font-medium transition-all duration-300 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-offset-background";

const variants = {
  primary: "bg-primary hover:bg-primary/90 text-white shadow-[0_0_20px_rgba(99,102,241,0.5)] hover:shadow-[0_0_30px_rgba(99,102,241,0.7)]",
  secondary: "bg-secondary hover:bg-secondary/90 text-white shadow-[0_0_20px_rgba(168,85,247,0.5)]",
  outline: "border border-white/20 hover:bg-white/10 text-white backdrop-blur-sm",
};

const Element = href ? 'a' : 'button';
---

<Element href={href} class:list={[baseStyles, variants[variant], className]} {...rest}>
  <slot />
</Element>
