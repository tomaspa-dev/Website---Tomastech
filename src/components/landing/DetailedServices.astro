---
import { Layout, ShoppingBag, Smartphone, TrendingUp, Monitor, Globe, Server, Image, Video } from 'lucide-react';
---

<section class="relative bg-black py-32 overflow-hidden" id="detailed-services">
  {/* Background Elements */}
  <div class="absolute top-0 left-0 w-full h-full overflow-hidden pointer-events-none">
    <div class="absolute top-1/4 left-1/4 w-[500px] h-[500px] bg-primary/5 rounded-full blur-[100px]"></div>
    <div class="absolute bottom-1/4 right-1/4 w-[500px] h-[500px] bg-purple-500/5 rounded-full blur-[100px]"></div>
  </div>

  <div class="container mx-auto px-6 relative z-10">
    <div class="text-center mb-20">
      <h2 class="text-4xl md:text-6xl font-bold text-white mb-6 tracking-tight">Comprehensive Solutions</h2>
      <p class="text-gray-400 max-w-2xl mx-auto text-xl">
        From simple landing pages to complex web applications, we cover every aspect of your digital presence.
      </p>
    </div>

    {/* Bento Grid Layout */}
    <div class="grid grid-cols-1 md:grid-cols-4 md:grid-rows-2 gap-6 max-w-7xl mx-auto h-auto md:h-[800px]">
      
      {/* 1. Web Development Core (Large - 2x2) */}
      <div class="md:col-span-2 md:row-span-2 group relative p-8 md:p-12 rounded-3xl bg-white/5 border border-white/10 overflow-hidden hover:border-primary/30 transition-all duration-500">
        <div class="absolute inset-0 bg-gradient-to-br from-primary/10 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
        <div class="absolute -right-10 -bottom-10 opacity-5 group-hover:opacity-10 transition-all duration-700 group-hover:scale-110 group-hover:rotate-[-5deg]">
          <Monitor size={300} />
        </div>
        
        <div class="relative z-10 h-full flex flex-col">
          <div class="w-16 h-16 rounded-2xl bg-primary/20 flex items-center justify-center text-primary mb-8">
            <Layout size={32} />
          </div>
          <h3 class="text-3xl md:text-4xl font-bold text-white mb-6">Web Development Core</h3>
          <p class="text-gray-400 text-lg mb-8 leading-relaxed">
            The foundation of your online identity. We build pixel-perfect, high-performance websites tailored to your brand.
          </p>
          
          <ul class="space-y-4 mt-auto">
            <li class="flex items-center gap-3 text-gray-300 group-hover:text-white transition-colors">
              <span class="w-2 h-2 rounded-full bg-primary"></span>
              <span class="font-medium">Personal & Portfolio Websites</span>
            </li>
            <li class="flex items-center gap-3 text-gray-300 group-hover:text-white transition-colors">
              <span class="w-2 h-2 rounded-full bg-primary"></span>
              <span class="font-medium">High-Conversion Landing Pages</span>
            </li>
            <li class="flex items-center gap-3 text-gray-300 group-hover:text-white transition-colors">
              <span class="w-2 h-2 rounded-full bg-primary"></span>
              <span class="font-medium">Corporate & Business Sites</span>
            </li>
            <li class="flex items-center gap-3 text-gray-300 group-hover:text-white transition-colors">
              <span class="w-2 h-2 rounded-full bg-primary"></span>
              <span class="font-medium">CMS Integration (WordPress/Sanity)</span>
            </li>
          </ul>
        </div>
      </div>

      {/* 2. E-Commerce (Medium - 1x1) */}
      <div class="md:col-span-1 md:row-span-1 group relative p-8 rounded-3xl bg-white/5 border border-white/10 overflow-hidden hover:border-purple-500/30 transition-all duration-500">
        <div class="absolute inset-0 bg-gradient-to-br from-purple-500/10 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
        
        <div class="relative z-10">
          <div class="w-12 h-12 rounded-xl bg-purple-500/20 flex items-center justify-center text-purple-400 mb-6">
            <ShoppingBag size={24} />
          </div>
          <h3 class="text-2xl font-bold text-white mb-4">E-Commerce</h3>
          <ul class="space-y-3">
            <li class="text-gray-400 text-sm group-hover:text-gray-200">Shopify & WooCommerce</li>
            <li class="text-gray-400 text-sm group-hover:text-gray-200">Custom Storefronts</li>
            <li class="text-gray-400 text-sm group-hover:text-gray-200">Payment Gateway Setup</li>
          </ul>
        </div>
      </div>

      {/* 3. Web Apps (Medium - 1x1) */}
      <div class="md:col-span-1 md:row-span-1 group relative p-8 rounded-3xl bg-white/5 border border-white/10 overflow-hidden hover:border-blue-500/30 transition-all duration-500">
        <div class="absolute inset-0 bg-gradient-to-br from-blue-500/10 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
        
        <div class="relative z-10">
          <div class="w-12 h-12 rounded-xl bg-blue-500/20 flex items-center justify-center text-blue-400 mb-6">
            <Smartphone size={24} />
          </div>
          <h3 class="text-2xl font-bold text-white mb-4">Web Apps</h3>
          <ul class="space-y-3">
            <li class="text-gray-400 text-sm group-hover:text-gray-200">Custom Dashboards</li>
            <li class="text-gray-400 text-sm group-hover:text-gray-200">SaaS MVPs</li>
            <li class="text-gray-400 text-sm group-hover:text-gray-200">Progressive Web Apps (PWA)</li>
          </ul>
        </div>
      </div>

      {/* 4. Growth & Optimization (Wide - 2x1) */}
      <div class="md:col-span-2 md:row-span-1 group relative p-8 rounded-3xl bg-white/5 border border-white/10 overflow-hidden hover:border-green-500/30 transition-all duration-500 flex flex-col md:flex-row items-center gap-8">
        <div class="absolute inset-0 bg-gradient-to-r from-green-500/10 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
        
        <div class="flex-1 relative z-10">
          <div class="flex items-center gap-4 mb-6">
            <div class="w-12 h-12 rounded-xl bg-green-500/20 flex items-center justify-center text-green-400">
              <TrendingUp size={24} />
            </div>
            <h3 class="text-2xl font-bold text-white">Growth & Performance</h3>
          </div>
          <p class="text-gray-400 text-sm mb-0">
            We don't just build websites; we build engines for growth. Optimized for speed, search engines, and user conversion.
          </p>
        </div>

        <div class="flex-1 grid grid-cols-2 gap-4 relative z-10 w-full">
          <div class="p-4 rounded-xl bg-white/5 border border-white/5 hover:bg-white/10 transition-colors">
            <Globe size={20} class="text-green-400 mb-2" />
            <span class="text-white text-sm font-medium block">Advanced SEO</span>
          </div>
          <div class="p-4 rounded-xl bg-white/5 border border-white/5 hover:bg-white/10 transition-colors">
            <Server size={20} class="text-green-400 mb-2" />
            <span class="text-white text-sm font-medium block">Fast Hosting</span>
          </div>
          <div class="p-4 rounded-xl bg-white/5 border border-white/5 hover:bg-white/10 transition-colors">
            <Image size={20} class="text-green-400 mb-2" />
            <span class="text-white text-sm font-medium block">Image Opt.</span>
          </div>
          <div class="p-4 rounded-xl bg-white/5 border border-white/5 hover:bg-white/10 transition-colors">
            <Video size={20} class="text-green-400 mb-2" />
            <span class="text-white text-sm font-medium block">Video Compress</span>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>
