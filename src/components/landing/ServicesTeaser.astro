---
import { Code2, Rocket, Smartphone, Palette, Shield, Zap } from 'lucide-react';
import ScrollReveal from '../ui/ScrollReveal';

const services = [
  {
    icon: "Code2",
    title: "Custom Development",
    description: "Tailored web solutions built with modern technologies. React, Astro, Next.js — performance-first architecture.",
    gradient: "from-primary-400 to-primary-600",
    glow: "rgba(129, 140, 248, 0.15)",
    iconColor: "text-primary-400",
  },
  {
    icon: "Palette",
    title: "Web Design",
    description: "Stunning interfaces that capture attention. We design experiences that convert visitors into loyal customers.",
    gradient: "from-secondary-400 to-secondary-600",
    glow: "rgba(192, 132, 252, 0.15)",
    iconColor: "text-secondary-400",
  },
  {
    icon: "Smartphone",
    title: "Responsive Design",
    description: "Pixel-perfect experiences on every device. From mobile to ultrawide — your site will look incredible everywhere.",
    gradient: "from-accent-400 to-accent-600",
    glow: "rgba(244, 114, 182, 0.15)",
    iconColor: "text-accent-400",
  },
  {
    icon: "Rocket",
    title: "SEO & Performance",
    description: "Blazing-fast load times and search engine optimization that puts you ahead of the competition.",
    gradient: "from-emerald-400 to-emerald-600",
    glow: "rgba(52, 211, 153, 0.15)",
    iconColor: "text-emerald-400",
  },
  {
    icon: "Shield",
    title: "Maintenance & Support",
    description: "Ongoing updates, security patches, and technical support. Your site stays fresh and protected.",
    gradient: "from-amber-400 to-amber-600",
    glow: "rgba(251, 191, 36, 0.15)",
    iconColor: "text-amber-400",
  },
  {
    icon: "Zap",
    title: "E-Commerce Solutions",
    description: "Complete online stores with payment integration, inventory management, and conversion-optimized checkout flows.",
    gradient: "from-cyan-400 to-cyan-600",
    glow: "rgba(34, 211, 238, 0.15)",
    iconColor: "text-cyan-400",
  },
];

const iconMap: Record<string, any> = { Code2, Palette, Smartphone, Rocket, Shield, Zap };
---

<section class="relative overflow-hidden py-32 section-gradient" id="services">
  <div class="container mx-auto px-6 relative z-10">
    {/* Header */}
    <div class="text-center mb-20 service-header">
      <span class="inline-block text-primary font-heading font-semibold tracking-wider uppercase text-sm mb-4">What We Do</span>
      <h2 class="text-4xl md:text-5xl lg:text-6xl font-bold text-text-primary mb-6 tracking-tight font-heading">
        Services That <span class="gradient-text">Deliver Results</span>
      </h2>
      <p class="text-text-secondary max-w-2xl mx-auto text-lg leading-relaxed">
        Comprehensive web solutions designed to elevate your brand and accelerate growth.
      </p>
    </div>
    
    {/* Cards Grid */}
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8 service-cards-container">
      {services.map((service, index) => {
        const IconComponent = iconMap[service.icon];
        return (
          <div 
            class="service-card group relative p-8 rounded-2xl glass-card gradient-border overflow-hidden transition-all duration-500 hover:-translate-y-2"
            data-glow={service.glow}
            style={`animation-delay: ${index * 100}ms;`}
          >
            {/* Hover glow background */}
            <div 
              class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none rounded-2xl"
              style={`background: radial-gradient(600px circle at var(--mouse-x, 50%) var(--mouse-y, 50%), ${service.glow}, transparent 40%);`}
            ></div>

            {/* Large background icon */}
            <div class="absolute -right-8 -bottom-8 opacity-[0.03] group-hover:opacity-[0.08] transform rotate-12 group-hover:rotate-0 group-hover:scale-125 transition-all duration-700 pointer-events-none">
              <IconComponent size={180} />
            </div>
            
            <div class="relative z-10">
              {/* Icon */}
              <div class={`w-14 h-14 rounded-xl bg-gradient-to-br ${service.gradient} bg-opacity-10 flex items-center justify-center mb-6 group-hover:scale-110 group-hover:rotate-3 transition-all duration-500 shadow-lg`}
                style={`background: linear-gradient(135deg, ${service.glow}, transparent);`}
              >
                <IconComponent size={28} class={service.iconColor} />
              </div>

              {/* Title */}
              <h3 class="text-xl font-bold text-text-primary mb-3 font-heading group-hover:text-primary transition-colors duration-300">
                {service.title}
              </h3>

              {/* Description */}
              <p class="text-text-secondary leading-relaxed text-sm group-hover:text-text-secondary/90 transition-colors">
                {service.description}
              </p>

              {/* Bottom accent line */}
              <div class={`mt-6 h-0.5 w-0 group-hover:w-full bg-gradient-to-r ${service.gradient} rounded-full transition-all duration-500`}></div>
            </div>
          </div>
        );
      })}
    </div>
  </div>
</section>

{/* Spotlight mouse tracking */}
<script>
  document.addEventListener('astro:page-load', () => {
    const cards = document.querySelectorAll('.service-card');
    
    cards.forEach((card) => {
      card.addEventListener('mousemove', (e) => {
        const rect = card.getBoundingClientRect();
        const x = e.clientX - rect.left;
        const y = e.clientY - rect.top;
        
        (card as HTMLElement).style.setProperty('--mouse-x', `${x}px`);
        (card as HTMLElement).style.setProperty('--mouse-y', `${y}px`);
      });
    });

    // Scroll-triggered entrance animation
    if (typeof IntersectionObserver !== 'undefined') {
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              const cards = entry.target.querySelectorAll('.service-card');
              cards.forEach((card, i) => {
                setTimeout(() => {
                  card.classList.add('animate-in');
                }, i * 100);
              });
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.1 }
      );

      const container = document.querySelector('.service-cards-container');
      if (container) observer.observe(container);
    }
  });
</script>

<style>
  .service-card {
    opacity: 0;
    transform: translateY(30px);
    transition: all 0.6s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .service-card.animate-in {
    opacity: 1;
    transform: translateY(0);
  }

  .service-card.animate-in:hover {
    transform: translateY(-8px);
  }
</style>
