---
import { MessageCircle } from 'lucide-react';
import ContactForm from './ContactForm';
import CTAFloatingObjects from './CTAFloatingObjects';
---

<section id="contact" class="py-24 relative overflow-hidden">
  <div class="absolute inset-0 bg-primary/5"></div>
  <CTAFloatingObjects client:visible />
  
  <div class="container mx-auto px-6 relative z-10">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      {/* Text on LEFT */}
      <div class="text-left">
        <span class="text-primary font-medium tracking-wider uppercase mb-4 block">Contact Us</span>
        <h2 class="text-4xl md:text-5xl font-bold text-white mb-6">
          Ready to Start Your Project?
        </h2>
        <p class="text-xl text-gray-400 mb-10">
          Let's discuss how we can help you achieve your digital goals. Fill out the form or chat with us directly.
        </p>
        
        <div class="flex flex-col sm:flex-row gap-4">
          <a 
            href="https://wa.link/4kne89" 
            target="_blank"
            class="inline-flex items-center justify-center gap-3 px-8 py-4 bg-[#25D366] text-white font-bold rounded-lg hover:bg-[#20bd5a] transition-all hover:scale-105 shadow-lg shadow-[#25D366]/20"
          >
            <MessageCircle className="w-6 h-6" />
            <span>Chat on WhatsApp</span>
          </a>
        </div>
      </div>
      
      {/* Form on RIGHT */}
      <div>
        <ContactForm client:load />
      </div>
    </div>
  </div>
</section>
