---
import { MessageCircle, Mail } from 'lucide-react';
import ContactForm from './ContactForm';
---

<section id="contact" class="py-24 lg:py-32 relative overflow-hidden">
  {/* Background gradient */}
  <div class="absolute inset-0 section-gradient"></div>
  <div class="absolute inset-0 bg-gradient-to-t from-background via-transparent to-transparent"></div>
  
  <div class="w-full max-w-7xl mx-auto px-8 sm:px-10 md:px-14 lg:px-20 relative z-10">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      {/* Text on LEFT */}
      <div class="cta-text text-left">
        <span class="cta-el inline-block text-primary font-heading font-semibold tracking-wider uppercase text-sm mb-4">Contact Us</span>
        <h2 class="cta-el text-4xl md:text-5xl lg:text-6xl font-bold text-text-primary mb-6 tracking-tight font-heading">
          Ready to Start Your <span class="gradient-text">Project?</span>
        </h2>
        <p class="cta-el text-lg text-text-secondary mb-10 leading-relaxed">
          Let's discuss how we can help you achieve your digital goals. Fill out the form or chat with us directly.
        </p>
        
        <div class="cta-el flex flex-col sm:flex-row gap-4">
          <a 
            href="https://wa.link/4kne89" 
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center gap-3 px-8 py-4 bg-[#25D366] text-white font-bold font-heading rounded-xl hover:bg-[#20bd5a] transition-all hover:scale-105 shadow-[0_0_20px_rgba(37,211,102,0.2)] hover:shadow-[0_0_30px_rgba(37,211,102,0.4)]"
          >
            <MessageCircle className="w-5 h-5" />
            <span>Chat on WhatsApp</span>
          </a>
          <a 
            href="mailto:hello@tomastech.dev"
            class="inline-flex items-center justify-center gap-3 px-8 py-4 rounded-xl border border-border text-text-primary hover:bg-surface-hover transition-all hover:scale-105 hover:border-border-hover font-heading font-semibold"
          >
            <Mail className="w-5 h-5" />
            <span>Send Email</span>
          </a>
        </div>
      </div>
      
      {/* Form on RIGHT */}
      <div class="cta-form">
        <ContactForm client:load />
      </div>
    </div>
  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  document.addEventListener('astro:page-load', () => {
    const section = document.querySelector('#contact');
    if (!section) return;

    // Left column stagger reveal
    gsap.fromTo(
      '.cta-text .cta-el',
      { opacity: 0, x: -50 },
      {
        opacity: 1, x: 0, duration: 0.8, stagger: 0.12, ease: 'power3.out',
        scrollTrigger: { trigger: '#contact', start: 'top 78%', once: true },
        onComplete: () => gsap.set('.cta-text .cta-el', { clearProps: 'transform' })
      }
    );

    // Right column (form) slides from right
    gsap.fromTo(
      '.cta-form',
      { opacity: 0, x: 60, scale: 0.97 },
      {
        opacity: 1, x: 0, scale: 1, duration: 0.9, ease: 'power3.out',
        scrollTrigger: { trigger: '#contact', start: 'top 74%', once: true },
        onComplete: () => gsap.set('.cta-form', { clearProps: 'transform' })
      }
    );
  });
</script>

<style>
  .cta-el { opacity: 0; }
  .cta-form { opacity: 0; }

  @media (prefers-reduced-motion: reduce) {
    .cta-el, .cta-form { opacity: 1 !important; transform: none !important; }
  }
</style>
