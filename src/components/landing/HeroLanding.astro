---
import { ArrowRight } from 'lucide-react';
import GeometricBackground from './GeometricBackground';
---

<section class="relative min-h-screen flex items-center justify-center overflow-hidden pt-20" id="hero">
  {/* Geometric 3D Background */}
  <div class="absolute inset-0 z-0">
    <GeometricBackground client:load />
  </div>
  
  <div class="container mx-auto px-6 relative z-10">
    <div class="max-w-5xl mx-auto text-center">
      <div class="hero-badge inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/5 border border-white/10 mb-6 opacity-0 backdrop-blur-md">
        <span class="w-2 h-2 rounded-full bg-primary animate-pulse shadow-[0_0_10px_#3B82F6]"></span>
        <span class="text-xs md:text-sm text-gray-300 tracking-wide uppercase font-medium">Premium Web Development</span>
      </div>
      
      <h1 class="text-5xl md:text-8xl font-bold text-white mb-4 md:mb-8 tracking-tighter leading-[1.2] perspective-1000">
        <div class="hero-line overflow-hidden pb-2 md:pb-8">
          <span class="inline-block transform translate-y-full origin-bottom-left">Crafting</span>
        </div>
        <div class="hero-line overflow-hidden pb-2 md:pb-8">
          <span class="inline-block transform translate-y-full origin-bottom-left"><span class="inline-block pb-4 text-transparent bg-clip-text bg-gradient-to-r from-primary via-purple-500 to-pink-500 animate-gradient-x">Digital Masterpieces</span></span>
        </div>
      </h1>
      
      <p class="hero-desc text-xl md:text-2xl text-gray-400 mb-8 md:mb-12 max-w-2xl mx-auto opacity-0 transform translate-y-4 leading-relaxed font-light">
        We merge art with code to build immersive digital experiences.
      </p>
      
      <div class="hero-cta flex flex-col sm:flex-row items-center justify-center gap-4 sm:gap-6 opacity-0 transform translate-y-4 w-full max-w-md mx-auto sm:max-w-none">
        <a 
          href="#contact" 
          class="magnetic-btn group relative inline-flex items-center justify-center gap-3 px-6 py-3 md:px-8 md:py-4 w-full sm:w-auto bg-white text-black font-bold rounded-full overflow-hidden transition-all duration-300 hover:scale-105 hover:shadow-[0_0_40px_rgba(59,130,246,0.5)]"
        >
          {/* Circular Ripple Effect - Smoother Transition */}
          <span class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-0 h-0 bg-gradient-to-r from-blue-600 to-purple-600 rounded-full transition-all duration-700 ease-out group-hover:w-[500px] group-hover:h-[500px] z-0"></span>
          
          <span class="relative z-10 transition-colors duration-300 group-hover:text-white">Start Project</span>
          
          {/* Arrow Swap Animation */}
          <div class="relative w-5 h-5 overflow-hidden z-10">
            <div class="absolute inset-0 flex items-center justify-center transition-all duration-300 ease-in-out group-hover:translate-x-full group-hover:opacity-0 group-hover:text-white">
              <ArrowRight size={20} />
            </div>
            <div class="absolute inset-0 flex items-center justify-center -translate-x-full opacity-0 transition-all duration-300 ease-in-out group-hover:translate-x-0 group-hover:opacity-100 text-white">
              <ArrowRight size={20} />
            </div>
          </div>
        </a>
        
        <a 
          href="/portfolio" 
          class="magnetic-btn inline-flex items-center justify-center px-6 py-3 md:px-8 md:py-4 w-full sm:w-auto rounded-full border border-white/10 text-white hover:bg-white/5 transition-all hover:border-white/30 hover:shadow-[0_0_20px_rgba(255,255,255,0.1)] backdrop-blur-sm"
        >
          View Portfolio
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .perspective-1000 {
    perspective: 1000px;
  }
  
  @keyframes gradient-x {
    0%, 100% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
  }
  .animate-gradient-x {
    background-size: 200% 200%;
    animation: gradient-x 5s ease infinite;
  }
  @keyframes shimmer {
    100% {
      transform: translateX(100%);
    }
  }
</style>

<script>
  import { gsap } from "gsap";
  
  document.addEventListener('astro:page-load', () => {
    // Check if hero elements exist before animating
    const heroBadge = document.querySelector(".hero-badge");
    const heroLines = document.querySelectorAll(".hero-line span");
    const heroDesc = document.querySelector(".hero-desc");
    const heroCta = document.querySelector(".hero-cta");
    
    // Only run animations if hero section exists
    if (heroBadge && heroLines.length > 0 && heroDesc && heroCta) {
      const tl = gsap.timeline();
      
      // Text Reveal Animation
      tl.to(".hero-badge", {
        opacity: 1,
        y: 0,
        duration: 1,
        ease: "power3.out"
      })
      .to(".hero-line span", {
        y: 0,
        rotate: 0,
        duration: 1.2,
        stagger: 0.15,
        ease: "power4.out"
      }, "-=0.6")
      .set(".hero-line", { overflow: "visible" }) // Fix for cutoff text: remove overflow hidden after animation
      .to(".hero-desc", {
        opacity: 1,
        y: 0,
        duration: 1,
        ease: "power3.out"
      }, "-=0.8")
      .to(".hero-cta", {
        opacity: 1,
        y: 0,
        duration: 1,
        ease: "power3.out"
      }, "-=0.8");
    }

    // Magnetic Buttons
    const buttons = document.querySelectorAll('.magnetic-btn');
    
    buttons.forEach((btn) => {
      btn.addEventListener('mousemove', (e: any) => {
        const rect = btn.getBoundingClientRect();
        const x = e.clientX - rect.left - rect.width / 2;
        const y = e.clientY - rect.top - rect.height / 2;
        
        gsap.to(btn, {
          x: x * 0.3,
          y: y * 0.3,
          duration: 0.3,
          ease: "power2.out"
        });
      });
      
      btn.addEventListener('mouseleave', () => {
        gsap.to(btn, {
          x: 0,
          y: 0,
          duration: 0.5,
          ease: "elastic.out(1, 0.3)"
        });
      });
    });
  });

</script>
