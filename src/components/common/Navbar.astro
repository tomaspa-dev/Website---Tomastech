---
import Button from '../ui/Button.astro';
import MobileMenu from '../ui/MobileMenu';
import { User, Briefcase } from 'lucide-react';

interface Props {
  isLanding?: boolean;
}

const { isLanding = false } = Astro.props;

const landingLinks = [
  { name: "Services", href: "#services" },
  { name: "Pricing", href: "#pricing" },
];

const portfolioLinks = [
  { name: "Work", href: "#work" },
  { name: "Process", href: "#process" },
  { name: "About", href: "#about" },
];

const links = isLanding ? landingLinks : portfolioLinks;
---

<nav id="navbar" class="fixed top-0 w-full z-50 transition-all duration-300 border-b border-transparent">
  <div class="container mx-auto px-6 h-24 flex items-center justify-between">
    <a href="/" class="block w-48 group relative overflow-hidden">
      <div class="absolute inset-0 bg-white/40 w-full h-full -translate-x-full skew-x-[-20deg] group-hover:animate-shine z-10"></div>
      <img src="/logo.png" alt="Tomastech Logo" class="w-full h-auto relative z-0 group-hover:brightness-125 transition-all duration-300" />
    </a>

    <div class="hidden md:flex items-center gap-4 lg:gap-8">
      {links.map((link) => (
        <a href={link.href} class="text-sm font-medium text-gray-300 hover:text-white transition-colors">
          {link.name}
        </a>
      ))}
      
      {isLanding ? (
        <>
          <a href="/portfolio" class="text-sm font-medium text-gray-300 hover:text-white transition-colors flex items-center gap-2">
            <Briefcase size={16} />
            <span class="hidden lg:inline">Portfolio</span>
            <span class="lg:hidden">Work</span>
          </a>
          
          <a 
            href="/client-access" 
            class="hidden md:flex items-center gap-2 text-sm font-medium text-gray-300 hover:text-white transition-colors ml-2"
            title="Client Login"
          >
            <div class="p-2 rounded-full bg-white/5 hover:bg-white/10 transition-colors">
              <User size={18} />
            </div>
            <span class="hidden lg:inline">Login</span>
          </a>

          <Button href="#contact" variant="primary" size="sm" class="ml-2 whitespace-nowrap">
            Start Project
          </Button>
        </>
      ) : (
        <Button href="#contact" variant="primary" size="sm" class="px-6">
          Let's Talk
        </Button>
      )}
    </div>

    <MobileMenu client:load isLanding={isLanding} />
  </div>
</nav>

<style>
  @keyframes shine {
    0% { transform: translateX(-100%) skewX(-20deg); }
    50% { transform: translateX(100%) skewX(-20deg); }
    100% { transform: translateX(100%) skewX(-20deg); }
  }
  .animate-shine {
    animation: shine 0.5s ease-in-out;
  }
</style>

<script>
  document.addEventListener('astro:page-load', () => {
    const navbar = document.getElementById('navbar');
    const container = navbar?.querySelector('.container');
    
    const updateNavbar = () => {
      if (window.scrollY > 20) {
        // Increased transparency to 70% as requested
        navbar?.classList.add('bg-[#0a0a0a]/70', 'backdrop-blur-xl', 'border-white/10', 'shadow-lg');
        navbar?.classList.remove('border-transparent');
        container?.classList.replace('h-24', 'h-20');
      } else {
        navbar?.classList.remove('bg-[#0a0a0a]/70', 'backdrop-blur-xl', 'border-white/10', 'shadow-lg');
        navbar?.classList.add('border-transparent');
        container?.classList.replace('h-20', 'h-24');
      }
    };

    // Initial check
    updateNavbar();

    // Scroll listener
    window.addEventListener('scroll', updateNavbar);
  });
</script>
