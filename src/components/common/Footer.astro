---
import { Github, Linkedin, Mail, Instagram, Phone, MessageCircle } from 'lucide-react';

const links = [
  { name: "Services", href: "#services" },
  { name: "Pricing", href: "#pricing" },
  { name: "Portfolio", href: "/portfolio" },
];

const social = [
  { icon: Github, href: "https://github.com/tomaspa-dev", label: "GitHub" },
  { icon: Linkedin, href: "https://www.linkedin.com/company/tomastechdev", label: "LinkedIn" },
  { icon: Instagram, href: "https://www.instagram.com/tomastechdev/", label: "Instagram" },
];
---

<footer class="border-t border-border pt-20 pb-12 relative overflow-hidden bg-background">
  <div class="container mx-auto px-6 md:px-12 relative z-10">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 mb-16">
      
      <div class="lg:col-span-2">
        <a href="/" class="block w-48 mb-6">
          <img src="/logo.png" alt="Tomastech Logo" class="logo-dark w-full h-auto" />
          <img src="/logo-light.png" alt="Tomastech Logo" class="logo-light w-full h-auto" />
        </a>
        <p class="text-text-secondary text-lg mb-8 max-w-md leading-relaxed">
          Helping businesses grow with high-performance web solutions. Let's build something amazing together.
        </p>
        <div class="flex gap-3">
          {social.map((item) => (
            <a 
              href={item.href} 
              target="_blank"
              rel="noopener noreferrer"
              aria-label={item.label}
              class="magnetic-btn w-10 h-10 rounded-full glass-card flex items-center justify-center text-text-muted hover:text-primary hover:border-primary/30 transition-all duration-300"
            >
              <item.icon size={20} />
            </a>
          ))}
          <a 
            href="https://x.com/tomastechdev" 
            target="_blank"
            rel="noopener noreferrer"
            aria-label="X (Twitter)"
            class="magnetic-btn w-10 h-10 rounded-full glass-card flex items-center justify-center text-text-muted hover:text-primary hover:border-primary/30 transition-all duration-300"
          >
            <svg viewBox="0 0 24 24" aria-hidden="true" class="w-5 h-5 fill-current"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"></path></svg>
          </a>
        </div>
      </div>

      <div>
        <h3 class="text-text-primary font-bold mb-6 font-heading">Quick Links</h3>
        <ul class="space-y-3">
          {links.map((link) => (
            <li>
              <a href={link.href} class="text-text-secondary hover:text-primary transition-colors">
                {link.name}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h3 class="text-text-primary font-bold mb-6 font-heading">Contact</h3>
        <div class="flex gap-4">
          
          <!-- Phone Copy -->
          <div class="relative group">
            <button 
              class="magnetic-btn w-12 h-12 rounded-xl glass-card flex items-center justify-center text-text-muted hover:text-primary hover:border-primary/30 transition-all duration-300 copy-btn"
              data-value="+51978395717"
              data-type="Phone number"
              aria-label="Copy Phone Number"
            >
              <Phone size={20} />
            </button>
            <div class="absolute bottom-full mb-3 left-1/2 -translate-x-1/2 bg-primary text-white text-xs font-bold px-3 py-1.5 rounded opacity-0 transition-opacity whitespace-nowrap pointer-events-none z-50 shadow-lg tooltip">
              Click to copy
            </div>
          </div>

          <!-- WhatsApp Link -->
          <div class="relative group">
            <a 
              href="https://wa.link/4kne89" 
              target="_blank"
              rel="noopener noreferrer"
              class="magnetic-btn w-12 h-12 rounded-xl glass-card flex items-center justify-center text-text-muted hover:text-[#25D366] hover:border-[#25D366]/30 transition-all duration-300"
              aria-label="Chat on WhatsApp"
            >
              <MessageCircle size={20} />
            </a>
            <div class="absolute bottom-full mb-3 left-1/2 -translate-x-1/2 bg-[#25D366] text-white text-xs font-bold px-3 py-1.5 rounded opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap pointer-events-none z-50 shadow-lg">
              WhatsApp
            </div>
          </div>

          <!-- Email Copy -->
          <div class="relative group">
            <button 
              class="magnetic-btn w-12 h-12 rounded-xl glass-card flex items-center justify-center text-text-muted hover:text-accent hover:border-accent/30 transition-all duration-300 copy-btn"
              data-value="hello@tomastech.dev"
              data-type="Email"
              aria-label="Copy Email"
            >
              <Mail size={20} />
            </button>
            <div class="absolute bottom-full mb-3 left-1/2 -translate-x-1/2 bg-accent text-white text-xs font-bold px-3 py-1.5 rounded opacity-0 transition-opacity whitespace-nowrap pointer-events-none tooltip z-50 shadow-lg">
              Click to copy
            </div>
          </div>
          
        </div>
      </div>

    </div>

    <div class="border-t border-border pt-8 flex flex-col md:flex-row justify-between items-center gap-4 text-sm text-text-muted">
      <p>&copy; {new Date().getFullYear()} Tomastech. All rights reserved.</p>
      <div class="flex gap-8">
        <a href="/privacy" class="hover:text-text-primary transition-colors">Privacy Policy</a>
        <a href="/terms" class="hover:text-text-primary transition-colors">Terms of Service</a>
      </div>
    </div>
  </div>
</footer>

<style>
  /* Theme-aware logo toggle — dark by default */
  .logo-light { display: none; }
  .logo-dark { display: block; }

  :global(.light) .logo-light { display: block; }
  :global(.light) .logo-dark { display: none; }
</style>

<script>
  import { gsap } from "gsap";

  document.addEventListener('astro:page-load', () => {
    // Magnetic Buttons
    const magneticBtns = document.querySelectorAll('footer .magnetic-btn');
    
    magneticBtns.forEach((btn: any) => {
      btn.addEventListener('mousemove', (e: MouseEvent) => {
        const rect = btn.getBoundingClientRect();
        const x = e.clientX - rect.left - rect.width / 2;
        const y = e.clientY - rect.top - rect.height / 2;
        
        gsap.to(btn, {
          x: x * 0.4,
          y: y * 0.4,
          duration: 0.3,
          ease: "power2.out"
        });
      });
      
      btn.addEventListener('mouseleave', () => {
        gsap.to(btn, {
          x: 0,
          y: 0,
          duration: 0.5,
          ease: "elastic.out(1, 0.3)"
        });
      });
    });

    // Copy functionality with toast notifications
    const copyButtons = document.querySelectorAll('.copy-btn');

    copyButtons.forEach(btn => {
      btn.addEventListener('click', async () => {
        const value = btn.getAttribute('data-value');
        const type = btn.getAttribute('data-type') || 'Value';
        
        if (!value) return;

        try {
          await navigator.clipboard.writeText(value);
          if (typeof (window as any).showToast === 'function') {
            (window as any).showToast(`${type} copied to clipboard!`, 'success');
          }
        } catch (err) {
          console.error('Failed to copy:', err);
          if (typeof (window as any).showToast === 'function') {
            (window as any).showToast('Failed to copy. Please try again.', 'error');
          }
        }
      });
    });
  });
</script>
