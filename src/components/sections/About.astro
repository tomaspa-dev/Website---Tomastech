---
import Button from '../ui/Button.astro';
---

<section id="about" class="py-24 relative overflow-hidden bg-black/40">
  <div class="container mx-auto px-4">
    <div class="grid lg:grid-cols-2 gap-12 items-center max-w-6xl mx-auto">
      
      <!-- Left Column: Vertical Video/Image -->
      <div class="relative w-full max-w-md mx-auto lg:max-w-none">
        <div class="absolute inset-0 bg-gradient-to-tr from-primary to-secondary opacity-20 blur-[100px] rounded-full"></div>
        
        <!-- Video Container (9:16 Aspect Ratio) -->
        <div class="relative aspect-[9/16] max-w-sm mx-auto rounded-2xl overflow-hidden border border-white/10 shadow-2xl group">
          <!-- Video Real -->
          <video 
            class="w-full h-full object-cover"
            autoplay
            muted
            loop
            playsinline
          >
            <source src="/video/Portafolio-video.webm" type="video/webm" />
            Your browser does not support the video tag.
          </video>
        </div>
      </div>

      <!-- Right Column: Content -->
      <div class="relative">
        <div class="inline-block mb-6 px-4 py-1.5 rounded-full border border-white/10 bg-white/5 backdrop-blur-sm">
          <span class="text-sm font-medium text-primary-300 tracking-wide">ABOUT ME</span>
        </div>
        
        <h2 class="text-4xl md:text-5xl font-bold mb-8 leading-tight">
          More than just code, <br/>
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary to-secondary">I build solutions.</span>
        </h2>
        
        <div class="relative pl-6 border-l-4 border-primary/50 mb-10">
          <p class="text-xl md:text-2xl text-gray-200 italic font-light leading-relaxed">
            "I believe that technology is an opportunity to solve real problems. My goal is to facilitate the transition to digital solutions that respect the user experience and drive business growth."
          </p>
        </div>

        <div class="space-y-6 text-lg text-gray-400 leading-relaxed mb-10">
          <p>
            Hi, I'm <span class="text-white font-medium">Tomas</span>. I specialize in building high-performance websites that help businesses stand out. With a focus on speed, security, and user experience, I create custom solutions that not only look great but also drive results.
          </p>
        </div>

        <!-- Profile Card -->
        <div class="flex items-center gap-4 p-4 rounded-xl bg-white/5 border border-white/10 w-fit">
          <div class="w-12 h-12 rounded-full overflow-hidden border-2 border-primary/50">
            <img src="/img/foto-perfil.webp" alt="Tomas Eduardo Pozu Asalde" class="w-full h-full object-cover" />
          </div>
          <div>
            <h4 class="text-white font-bold leading-none">Tomas Eduardo Pozu Asalde</h4>
            <span class="text-sm text-primary-300">Frontend Engineer</span>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>
