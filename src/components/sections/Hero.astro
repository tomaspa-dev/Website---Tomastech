---
import Button from '../ui/Button.astro';
import SubtleParallax from '../ui/SubtleParallax';
---

<section class="hero-portfolio relative min-h-screen flex items-center justify-center overflow-hidden">
  <!-- Theme-aware background -->
  <div class="absolute inset-0 z-0 hero-pf-bg transition-colors duration-500"></div>
  
  <!-- Subtle Parallax Background -->
  <SubtleParallax client:load />
  
  <!-- Gradient Overlay -->
  <div class="absolute inset-0 z-[2] hero-pf-overlay pointer-events-none"></div>

  <div class="container mx-auto px-4 relative z-10 text-center pt-8 sm:pt-14 md:pt-20">
    <!-- Badge -->
    <div class="hero-anim mb-6">
      <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-border bg-surface backdrop-blur-sm">
        <span class="text-sm font-medium text-primary tracking-wide">✨ PREMIUM FREELANCE WEB DEVELOPER</span>
      </div>
    </div>
    
    <!-- Title with sliding word animation -->
    <h1 class="mb-8 leading-tight tracking-tight">
      <span class="hero-title-line block overflow-hidden">
        <span class="hero-title-word block text-5xl md:text-7xl lg:text-8xl font-bold text-text-primary">
          Web innovation
        </span>
      </span>
      <span class="hero-title-line block overflow-hidden mt-2">
        <span class="hero-title-word block text-5xl md:text-7xl lg:text-8xl font-bold text-transparent bg-clip-text bg-gradient-to-r from-primary via-secondary to-accent">
          to stand out
        </span>
      </span>
    </h1>

    <p class="hero-anim text-xl md:text-2xl text-text-secondary mb-10 max-w-2xl mx-auto leading-relaxed font-light">
      I build high-performance websites that convert visitors into loyal customers. Fast, secure, and stunningly designed.
    </p>

    <div class="hero-anim flex flex-col sm:flex-row items-center justify-center gap-4">
      <Button href="#contact" variant="primary" class="w-full sm:w-auto min-w-[180px]">
        Start your project
      </Button>
      <Button href="#work" variant="outline" class="w-full sm:w-auto min-w-[180px]">
        View my work
      </Button>
    </div>
  </div>
</section>

<script>
  import { gsap } from 'gsap';

  function initHeroAnimations() {
    const section = document.querySelector('.hero-portfolio');
    if (!section) return;
    
    const heroAnims = section.querySelectorAll('.hero-anim');
    const titleWords = section.querySelectorAll('.hero-title-word');
    
    if (heroAnims.length === 0 && titleWords.length === 0) return;

    // GSAP enhances after CSS initial reveal — staggered subtitle & buttons
    const tl = gsap.timeline({ delay: 0.6 });
    
    const subtitle = heroAnims[1]; // <p> subtitle
    const ctaBlock = heroAnims[2]; // buttons container
    
    if (subtitle) {
      tl.fromTo(subtitle, 
        { opacity: 0, y: 20 },
        { opacity: 1, y: 0, duration: 0.8, ease: 'power3.out' }
      );
    }
    if (ctaBlock) {
      tl.fromTo(ctaBlock, 
        { opacity: 0, y: 20 },
        { opacity: 1, y: 0, duration: 0.7, ease: 'power3.out' },
        '-=0.4'
      );
    }

    // Safety fallback
    setTimeout(() => {
      heroAnims.forEach((el) => { 
        (el as HTMLElement).style.opacity = '1';
        (el as HTMLElement).style.transform = 'none';
      });
      titleWords.forEach((el) => { (el as HTMLElement).style.transform = 'none'; });
    }, 3000);
  }

  // Run on load and Astro page transitions
  document.addEventListener('astro:page-load', initHeroAnimations);
  window.addEventListener('load', initHeroAnimations);
</script>

<style>
  /* Initial state: badge fades in first */
  .hero-anim {
    opacity: 0;
    animation: fadeInUp 0.7s ease-out forwards;
    will-change: opacity, transform;
  }
  .hero-anim:nth-child(1) { animation-delay: 0s; }

  /* Title words reveal — staggered slide-up */
  .hero-title-word {
    transform: translateY(110%);
    animation: slideUp 0.9s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    will-change: transform;
  }
  /* Staggered delays per title line */
  .hero-title-line:nth-child(1) .hero-title-word { animation-delay: 0.1s; }
  .hero-title-line:nth-child(2) .hero-title-word { animation-delay: 0.25s; }

  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(15px); }
    to { opacity: 1; transform: translateY(0); }
  }
  @keyframes slideUp {
    to { transform: translateY(0); }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-anim {
      opacity: 1 !important;
      transform: none !important;
      animation: none !important;
    }
    .hero-title-word {
      transform: none !important;
      animation: none !important;
    }
  }

  /* Dark mode (default) */
  :global(:not(.light)) .hero-pf-bg,
  :global(.dark) .hero-pf-bg {
    background: linear-gradient(to bottom, #050510, #050510, rgba(99, 102, 241, 0.05));
  }
  :global(:not(.light)) .hero-pf-overlay,
  :global(.dark) .hero-pf-overlay {
    background: linear-gradient(to top, rgba(5,5,16,0.4), transparent, transparent);
  }

  /* Light mode */
  :global(.light) .hero-pf-bg {
    background: linear-gradient(to bottom, #f8fafc, #eef2ff, rgba(99, 102, 241, 0.04));
  }
  :global(.light) .hero-pf-overlay {
    background: linear-gradient(to top, rgba(248,250,252,0.4), transparent, transparent);
  }
</style>

