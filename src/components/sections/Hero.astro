---
import Button from '../ui/Button.astro';
import SubtleParallax from '../ui/SubtleParallax';
---

<section class="relative min-h-screen flex items-center justify-center overflow-hidden bg-gradient-to-b from-black via-black to-primary/5">
  <!-- Subtle Parallax Background -->
  <SubtleParallax client:load />
  
  <!-- Gradient Overlay -->
  <div class="absolute inset-0 z-0 bg-gradient-to-t from-black/40 via-transparent to-transparent pointer-events-none"></div>

  <div class="container mx-auto px-4 relative z-10 text-center pt-20">
    <div class="inline-block mb-6 px-4 py-1.5 rounded-full border border-white/10 bg-white/5 backdrop-blur-sm">
      <span class="text-sm font-medium text-primary-300 tracking-wide">✨ PREMIUM FREELANCE WEB DEVELOPER</span>
    </div>
    
    <h1 class="text-5xl md:text-7xl lg:text-8xl font-bold mb-8 leading-tight tracking-tight">
      Web innovation <br />
      <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary via-secondary to-accent">
        to stand out
      </span>
    </h1>

    <p class="text-xl md:text-2xl text-gray-400 mb-10 max-w-2xl mx-auto leading-relaxed font-light">
      I build high-performance websites that convert visitors into loyal customers. Fast, secure, and stunningly designed.
    </p>

    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <Button href="#contact" variant="primary" class="w-full sm:w-auto min-w-[180px]">
        Start your project
      </Button>
      <Button href="#work" variant="outline" class="w-full sm:w-auto min-w-[180px]">
        View my work
      </Button>
    </div>
  </div>
</section>
