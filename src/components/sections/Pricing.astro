---
import Button from '../ui/Button.astro';
import Card from '../ui/Card.astro';
import { Check } from 'lucide-react';

const plans = [
  {
    name: "Basic",
    price: "$1,500",
    period: "/month",
    description: "Landing Pages, Corporate Websites",
    features: [
      "Responsive design",
      "Basic SEO optimization",
      "Up to 3 pages",
      "Contact form integration",
      "1 revision included"
    ],
    cta: "Get Started",
    popular: false,
  },
  {
    name: "Professional",
    price: "$2,500",
    period: "/month",
    description: "Designed for growing businesses needing advanced features.",
    features: [
      "Custom design",
      "Advanced SEO features",
      "Up to 5 pages",
      "Blog setup",
      "E-commerce integration",
      "3 revisions included"
    ],
    cta: "Get Started",
    popular: true,
  },
  {
    name: "Enterprise",
    price: "Custom",
    period: "",
    description: "For large organizations requiring robust, complex solutions.",
    features: [
      "Complex integrations",
      "Advanced SEO features",
      "Custom pages",
      "Custom functionality",
      "Priority support",
      "5 revisions included"
    ],
    cta: "Contact Us",
    popular: false,
  },
];
---

<section id="pricing" class="py-24 bg-white/5">
  <div class="container mx-auto px-4">
    <div class="text-center max-w-3xl mx-auto mb-16">
      <h2 class="text-4xl md:text-5xl font-bold mb-6">Simple Pricing</h2>
      <p class="text-xl text-gray-400">
        Transparent pricing plans that scale with your business needs. No hidden fees.
      </p>
      <p class="text-sm text-gray-500 mt-2">
        (*) Taxes not included / Starts at
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {plans.map((plan) => (
        <Card class={`relative ${plan.popular ? 'border-primary shadow-[0_0_30px_rgba(99,102,241,0.15)]' : ''}`}>
          {plan.popular && (
            <div class="absolute -top-4 left-1/2 -translate-x-1/2 bg-primary text-white px-4 py-1 rounded-full text-sm font-medium">
              Most Popular
            </div>
          )}
          <div class="mb-8">
            <h3 class="text-xl font-bold mb-2">{plan.name}</h3>
            <div class="flex items-baseline gap-1 mb-4">
              <span class="text-4xl font-bold">{plan.price}</span>
              <span class="text-gray-400">{plan.period}</span>
            </div>
            <p class="text-gray-400 text-sm">{plan.description}</p>
          </div>

          <ul class="space-y-4 mb-8">
            {plan.features.map((feature) => (
              <li class="flex items-start gap-3 text-sm text-gray-300">
                <Check size={18} class="text-primary shrink-0 mt-0.5" />
                <span>{feature}</span>
              </li>
            ))}
          </ul>

          <Button 
            href="#contact" 
            variant={plan.popular ? 'primary' : 'outline'} 
            class="w-full"
          >
            {plan.cta}
          </Button>
        </Card>
      ))}
    </div>
  </div>
</section>
