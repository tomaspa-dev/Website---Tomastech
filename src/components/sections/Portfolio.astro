---
import PortfolioGrid from './PortfolioGrid';
import PortfolioBackgroundEffects from '../landing/PortfolioBackgroundEffects';
---

<section id="work" class="py-32 relative">
    <div class="absolute inset-0 section-gradient opacity-50"></div>
    <PortfolioBackgroundEffects client:visible />
    
    <div class="container mx-auto px-4 relative z-10">
        <div class="text-center max-w-3xl mx-auto mb-16">
            <div class="inline-block mb-4 px-4 py-1.5 rounded-full border border-border bg-surface backdrop-blur-sm">
                <span class="text-sm font-medium text-primary tracking-wide">PORTFOLIO</span>
            </div>
            <h2 class="text-4xl md:text-5xl font-bold text-text-primary mb-6 leading-tight">
                Frontend <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary to-secondary">Engineer</span>
            </h2>
            <p class="text-text-secondary text-lg leading-relaxed">
                A comprehensive collection of my work, categorized by technology and complexity. From high-conversion landing pages to complex web applications.
            </p>
        </div>

        <PortfolioGrid client:load />

        <div class="mt-20 text-center">
            <p class="text-text-muted mb-6">Want to see more?</p>
            <a href="https://github.com/tomaspa-dev" target="_blank" class="inline-flex items-center gap-2 px-6 py-3 rounded-lg border border-border hover:bg-surface-hover transition-colors text-text-primary">
                Check my GitHub
            </a>
        </div>
    </div>
</section>
