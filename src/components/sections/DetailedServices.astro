---
import { 
  Globe, 
  ShoppingCart, 
  TrendingUp, 
  Wrench, 
  Zap, 
  MessageSquare 
} from 'lucide-react';
---

<section id="detailed-services" class="py-32 relative overflow-hidden bg-black/30">
  <!-- Background gradient -->
  <div class="absolute inset-0 bg-gradient-to-b from-transparent via-primary/5 to-transparent pointer-events-none"></div>
  
  <div class="container mx-auto px-4 relative z-10">
    <!-- Header -->
    <div class="text-center max-w-3xl mx-auto mb-16">
      <span class="text-primary font-medium tracking-wider uppercase mb-4 block">Specialized Solutions</span>
      <h2 class="text-3xl md:text-4xl font-display font-bold text-white mb-6">
        Detailed <span class="text-primary">Services</span>
      </h2>
      <p class="text-gray-400 text-lg">
        From custom development to growth strategies, end-to-end solutions tailored to your business goals.
      </p>
    </div>

    <!-- Bento Grid -->
    <div class="bento-grid">
      <!-- Large: Web Development (Span 3 - Half) -->
      <div class="bento-item bento-large group" data-delay="0">
        <div class="bento-content">
          <div class="bento-icon">
            <Globe size={40} />
          </div>
          <h3 class="text-2xl font-bold text-white mb-3">Custom Web Development</h3>
          <p class="text-gray-400 leading-relaxed mb-4">
            Tailored websites and complex web applications built with Astro, React, and Next.js for speed and scalability.
          </p>
          <ul class="space-y-2 text-sm text-gray-300">
            <li class="flex items-center gap-2">
              <span class="w-1.5 h-1.5 rounded-full bg-primary"></span>
              Astro, React, Next.js
            </li>
            <li class="flex items-center gap-2">
              <span class="w-1.5 h-1.5 rounded-full bg-primary"></span>
              Headless CMS Integration
            </li>
            <li class="flex items-center gap-2">
              <span class="w-1.5 h-1.5 rounded-full bg-primary"></span>
              API Development & Integration
            </li>
          </ul>
          <div class="bento-glow"></div>
        </div>
      </div>

      <!-- Medium: E-commerce (Span 3 - Half) -->
      <div class="bento-item bento-medium group" data-delay="0.1">
        <div class="bento-content">
          <div class="bento-icon">
            <ShoppingCart size={36} />
          </div>
          <h3 class="text-2xl font-bold text-white mb-3">E-commerce Solutions</h3>
          <p class="text-gray-400 leading-relaxed mb-4">
            Complete online stores with Shopify or WooCommerce, including payments and inventory management.
          </p>
          <ul class="space-y-2 text-sm text-gray-300">
            <li class="flex items-center gap-2">
              <span class="w-1 h-1 rounded-full bg-primary"></span>
              Shopify & WooCommerce
            </li>
            <li class="flex items-center gap-2">
              <span class="w-1 h-1 rounded-full bg-primary"></span>
              Custom Development
            </li>
            <li class="flex items-center gap-2">
              <span class="w-1 h-1 rounded-full bg-primary"></span>
              Payment Gateway Setup
            </li>
          </ul>
          <div class="bento-glow"></div>
        </div>
      </div>

      <!-- Medium: Growth Strategies (Span 4 - Two Thirds) -->
      <div class="bento-item bento-two-thirds group" data-delay="0.2">
        <div class="bento-content">
          <div class="bento-icon">
            <TrendingUp size={36} />
          </div>
          <h3 class="text-2xl font-bold text-white mb-3">Growth Strategies</h3>
          <p class="text-gray-400 leading-relaxed mb-4">
            SEO optimization, performance tuning, and analytics setup to drive traffic and conversions.
          </p>
          <ul class="space-y-2 text-sm text-gray-300">
            <li class="flex items-center gap-2">
              <span class="w-1 h-1 rounded-full bg-primary"></span>
              Technical SEO
            </li>
            <li class="flex items-center gap-2">
              <span class="w-1 h-1 rounded-full bg-primary"></span>
              Analytics & Tracking
            </li>
          </ul>
          <div class="bento-glow"></div>
        </div>
      </div>

      <!-- Small: Maintenance (Span 2 - One Third) -->
      <div class="bento-item bento-one-third group" data-delay="0.3">
        <div class="bento-content">
          <div class="bento-icon bento-icon-small">
            <Wrench size={28} />
          </div>
          <h3 class="text-xl font-bold text-white mb-2">Maintenance & Support</h3>
          <p class="text-gray-400 text-sm leading-relaxed">
            Ongoing updates, security patches, and technical support.
          </p>
          <div class="bento-glow"></div>
        </div>
      </div>

      <!-- Small: Performance (Span 3 - Half) -->
      <div class="bento-item bento-half group" data-delay="0.4">
        <div class="bento-content">
          <div class="bento-icon bento-icon-small">
            <Zap size={28} />
          </div>
          <h3 class="text-xl font-bold text-white mb-2">Performance Optimization</h3>
          <p class="text-gray-400 text-sm leading-relaxed">
            Speed audits and optimization for lightning-fast load times.
          </p>
          <div class="bento-glow"></div>
        </div>
      </div>

      <!-- Small: Consulting (Span 3 - Half) -->
      <div class="bento-item bento-half group" data-delay="0.5">
        <div class="bento-content">
          <div class="bento-icon bento-icon-small">
            <MessageSquare size={28} />
          </div>
          <h3 class="text-xl font-bold text-white mb-2">Technical Consulting</h3>
          <p class="text-gray-400 text-sm leading-relaxed">
            Expert guidance on tech stack, architecture, and best practices.
          </p>
          <div class="bento-glow"></div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  /* Bento Grid Layout */
  .bento-grid {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 1rem;
    max-width: 1200px;
    margin: 0 auto;
  }

  /* Grid Item Sizes */
  .bento-large {
    grid-column: span 3;
    grid-row: span 1;
  }

  .bento-medium {
    grid-column: span 3;
  }

  .bento-small {
    grid-column: span 2;
  }

  /* New Utility Classes for Layout Control */
  .bento-half {
    grid-column: span 3;
  }

  .bento-two-thirds {
    grid-column: span 4;
  }

  .bento-one-third {
    grid-column: span 2;
  }

  /* Responsive adjustments */
  @media (max-width: 1024px) {
    .bento-grid {
      grid-template-columns: repeat(4, 1fr);
    }

    .bento-large,
    .bento-medium,
    .bento-small,
    .bento-half,
    .bento-two-thirds,
    .bento-one-third {
      grid-column: span 2;
    }
  }

  @media (max-width: 768px) {
    .bento-grid {
      grid-template-columns: 1fr;
      gap: 1rem;
    }

    .bento-large,
    .bento-medium,
    .bento-small,
    .bento-half,
    .bento-two-thirds,
    .bento-one-third {
      grid-column: span 1;
      grid-row: span 1;
    }
  }

  /* Bento Item Styling */
  .bento-item {
    position: relative;
    background: linear-gradient(135deg, rgba(255, 255, 255, 0.05), rgba(255, 255, 255, 0.02));
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 1.5rem;
    padding: 2rem;
    overflow: hidden;
    transition: all 0.5s cubic-bezier(0.25, 0.4, 0.25, 1);
    opacity: 0;
    animation: bentoFadeIn 0.8s ease-out forwards;
    animation-delay: calc(var(--delay, 0) * 0.1s);
  }

  .bento-item::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(79, 70, 229, 0.1), transparent);
    opacity: 0;
    transition: opacity 0.5s ease;
  }

  .bento-item:hover {
    transform: translateY(-4px);
    border-color: rgba(79, 70, 229, 0.4);
    box-shadow: 
      0 20px 40px rgba(0, 0, 0, 0.4),
      0 0 0 1px rgba(79, 70, 229, 0.2),
      0 0 40px rgba(79, 70, 229, 0.15);
  }

  .bento-item:hover::before {
    opacity: 1;
  }

  /* Content */
  .bento-content {
    position: relative;
    z-index: 10;
    height: 100%;
    display: flex;
    flex-direction: column;
  }

  /* Icon */
  .bento-icon {
    width: 80px;
    height: 80px;
    border-radius: 1.25rem;
    background: linear-gradient(135deg, rgba(79, 70, 229, 0.2), rgba(139, 92, 246, 0.2));
    display: flex;
    align-items: center;
    justify-content: center;
    color: #4f46e5;
    margin-bottom: 1.5rem;
    transition: all 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .bento-icon-small {
    width: 60px;
    height: 60px;
    margin-bottom: 1rem;
  }

  .bento-item:hover .bento-icon {
    transform: scale(1.1) rotate(5deg);
    background: linear-gradient(135deg, rgba(79, 70, 229, 0.3), rgba(139, 92, 246, 0.3));
    box-shadow: 0 10px 30px rgba(79, 70, 229, 0.3);
  }

  /* Glow effect - DISABLED per user request */
  .bento-glow {
    display: none;
  }

  @keyframes bentoFadeIn {
    from {
      opacity: 0;
      transform: translateY(20px) scale(0.95);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  /* Reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .bento-item {
      animation: none;
      opacity: 1;
    }

    .bento-item:hover {
      transform: none;
    }

    .bento-glow {
      animation: none;
    }
  }
</style>

<script>
  // Set delay data attribute for staggered animation
  document.addEventListener('DOMContentLoaded', () => {
    const items = document.querySelectorAll('.bento-item');
    items.forEach((item, index) => {
      item.style.setProperty('--delay', index.toString());
    });
  });
</script>
