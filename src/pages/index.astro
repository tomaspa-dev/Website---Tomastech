---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/common/Navbar.astro';
import HeroLanding from '../components/landing/HeroLanding.astro';
import ServicesTeaser from '../components/landing/ServicesTeaser.astro';
import Pricing from '../components/sections/Pricing.astro';
import ConversionCTA from '../components/landing/ConversionCTA.astro';
import Footer from '../components/common/Footer.astro';
---

<BaseLayout title="Tomastech | Web Solutions & Digital Transformation">
  <Navbar isLanding={true} />
  <main>
    <HeroLanding />
    <ServicesTeaser />
    <Pricing />
    <ConversionCTA />
  </main>
  
  <Footer />
</BaseLayout>
