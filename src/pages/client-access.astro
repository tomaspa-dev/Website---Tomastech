---
import BaseLayout from '../layouts/BaseLayout.astro';
import ClientAccessPage from '../components/client/ClientAccessPage';
import { ArrowLeft } from 'lucide-react';
---

<BaseLayout title="Client Access | Tomastech">
  <main class="relative min-h-screen flex items-center justify-center overflow-hidden bg-black">
    
    <!-- Back Button -->
    <a 
      href="/" 
      class="absolute top-8 left-8 z-50 flex items-center gap-2 text-gray-400 hover:text-white transition-colors group"
    >
      <div class="w-10 h-10 rounded-full border border-white/10 flex items-center justify-center group-hover:bg-white/10 transition-all">
        <ArrowLeft size={18} />
      </div>
      <span class="text-sm font-medium opacity-0 group-hover:opacity-100 -translate-x-2 group-hover:translate-x-0 transition-all duration-300">Back to Home</span>
    </a>

    <!-- The Vault Experience -->
    <ClientAccessPage client:load />

  </main>
</BaseLayout>
